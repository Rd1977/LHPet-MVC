@{
    ViewData["Title"] = "LH-Pet";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Sistema LH-Pet</h1>
        <p class="text-muted">Clientes e fornecedores da clínica veterinária</p>
    </div>

    <div class="card shadow-sm mb-5">
        <div class="card-header bg-dark text-white">
            <h2 class="h5 mb-0">Clientes</h2>
        </div>
        <div class="card-body">
            <table class="table table-striped table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nº</th>
                        <th>Nome</th>
                        <th>CPF</th>
                        <th>E-mail</th>
                        <th>Paciente</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in ViewBag.ListaClientes)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td>@c.Nome</td>
                            <td>@c.Cpf</td>
                            <td>@c.Email</td>
                            <td>@c.Paciente</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h2 class="h5 mb-0">Fornecedores</h2>
        </div>
        <div class="card-body">
            <table class="table table-striped table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nº</th>
                        <th>Nome</th>
                        <th>CNPJ</th>
                        <th>E-mail</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in ViewBag.ListaFornecedores)
                    {
                        <tr>
                            <td>@f.Id</td>
                            <td>@f.Nome</td>
                            <td>@f.Cnpj</td>
                            <td>@f.Email</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>